PLAYER_NUMBER=4
DATE=2025-04-24
START_TIME=09:00
END_TIME=20:00
DURATION=60
PLACE_DISTANCE=100
PLACE_LATITUDE=39.4712827
PLACE_LONGITUDE=-0.3405378
BEARER_TOKEN=
FINGERPRINT=

# Automatic session refresh (Dink identity API — see docs/auth-refresh.md).
# With DINK_EMAIL/DINK_PASSWORD set, the bot signs in and keeps the session
# alive on its own; BEARER_TOKEN/FINGERPRINT above are optional bootstrap.
DINK_EMAIL=
DINK_PASSWORD=
# Rotating refresh token (auto-captured/persisted; usually leave blank).
REFRESH_TOKEN=
# Identity endpoints (defaults shown — only override if Dink changes them).
DINK_SIGNIN_URL=https://dink.social/api/identity/auth/sign-in
DINK_REFRESH_URL=https://dink.social/api/identity/auth/refresh

# Session file written by scripts/capture_dink_session.py (mitmweb sidecar)
DINK_SESSION_FILE=.dink_session.json

# Keepalive probe (POST /api/users/push-token — validity check, not token refresh)
DINK_PUSH_TOKEN=
DINK_PROBE_URL=https://dink.social/api/users/push-token
DINK_KEEPALIVE_INTERVAL=300